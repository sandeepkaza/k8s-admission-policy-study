{
 "apiVersion": "v1",
 "kind": "Pod",
 "metadata": {
  "name": "bad-r10",
  "labels": {
   "app.kubernetes.io/name": "bench"
  }
 },
 "spec": {
  "automountServiceAccountToken": false,
  "securityContext": {
   "runAsNonRoot": true,
   "seccompProfile": {
    "type": "RuntimeDefault"
   }
  },
  "containers": [
   {
    "name": "app",
    "image": "ghcr.io/evil/nginx:1.27",
    "resources": {
     "limits": {
      "cpu": "100m",
      "memory": "128Mi"
     }
    },
    "securityContext": {
     "privileged": false,
     "allowPrivilegeEscalation": false,
     "readOnlyRootFilesystem": true,
     "runAsNonRoot": true,
     "capabilities": {
      "drop": [
       "ALL"
      ]
     },
     "seccompProfile": {
      "type": "RuntimeDefault"
     }
    }
   }
  ]
 }
}